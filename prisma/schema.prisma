generator client {
  provider = "prisma-client-js"
  output = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  standard_user
}

enum ProjectStatus {
  pending
  in_progress
  blocked
  done
}

enum TaskStatus {
  pending
  done
}

enum MovementType {
  income
  expense
}

// ============================================
// MODELS
// ============================================

model Tenant {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  isActive      Boolean   @default(true) @map("is_active")
  name          String    @db.VarChar(255)
  slug          String    @unique @db.VarChar(100)
  nif           String?   @unique @db.VarChar(50)
  email         String?   @unique @db.VarChar(254)
  address       String?   @db.VarChar(500)
  website       String?   @db.VarChar(500)
  phone1        String?   @db.VarChar(30)
  phone2        String?   @db.VarChar(30)
  logoPath      String?   @map("logo_path") @db.VarChar(500)
  primaryColor  String?   @map("primary_color") @db.Char(7)
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  users         User[]
  clients       Client[]
  projects      Project[]
  tasks         Task[]
  movements     Movement[]
  documents     Document[]
  phones        Phone[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  role                UserRole  @default(standard_user)
  createdAt           DateTime  @default(now()) @map("created_at")
  username            String   @unique @db.VarChar(255)
  email               String   @unique @db.VarChar(254)
  nif                 String   @db.VarChar(50)
  passwordHash        String   @map("password_hash") @db.VarChar(255)
  isActive            Boolean   @default(false) @map("is_active")
  activationToken     String?   @map("activation_token") @db.VarChar(100)
  activationSentAt    DateTime? @map("activation_sent_at")
  tokenVersion        Int       @default(0) @map("token_version")
  activatedAt         DateTime? @map("activated_at")
  updatedAt           DateTime? @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Relations
  tenant              Tenant    @relation(fields: [tenantId], references: [id])

  clients     Client[]    @relation("ClientCreatedBy")
  projects    Project[]   @relation("ProjectCreatedBy")
  tasks       Task[]      @relation("TaskCreatedBy")
  movements   Movement[]  @relation("MovementCreatedBy")
  documents   Document[]  @relation("DocumentCreatedBy")
  phones      Phone[]     @relation("PhoneCreatedBy")

  @@unique([tenantId, nif], name: "uq_users_nif_tenant")

  @@map("users")
}

model Client {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  createdById      String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  name        String   @db.VarChar(255)
  surname     String?   @db.VarChar(255)
  email       String?   @db.VarChar(254)
  nif         String?   @db.VarChar(50)
  notes       String?
  updatedAt   DateTime? @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdBy   User   @relation("ClientCreatedBy", fields: [createdById], references: [id])
  projects    Project[]
  phones      Phone[]

  @@unique([tenantId, email], name: "uq_clients_email_tenant")
  @@unique([tenantId, nif],   name: "uq_clients_nif_tenant")
  @@map("clients")
}

model Project {
  id          String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  clientId    String?       @map("client_id") @db.Uuid
  createdById      String        @map("created_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")
  status      ProjectStatus @default(pending)
  name        String?       @db.VarChar(255)
  address     String?       @db.VarChar(500)
  lat         Decimal?      @db.Decimal(10, 7)
  long        Decimal?      @db.Decimal(10, 7)
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  notes       String?
  updatedAt   DateTime?     @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  // Relations
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  client      Client?       @relation(fields: [clientId], references: [id])
  createdBy        User          @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  tasks       Task[]
  movements   Movement[]
  documents   Document[]

  @@map("projects")
}

model Phone {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  clientId    String    @map("client_id") @db.Uuid
  createdById      String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  label       String?   @db.VarChar(100)
  number      String?   @db.VarChar(25)
  updatedAt   DateTime? @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  client      Client    @relation(fields: [clientId], references: [id])
  createdBy   User   @relation("PhoneCreatedBy", fields: [createdById], references: [id])
  @@map("phones")
}

model Task {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  projectId   String     @map("project_id") @db.Uuid
  createdById      String     @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")
  status      TaskStatus @default(pending)
  title       String    @db.VarChar(255)
  description String?
  dueDate     DateTime?  @map("due_date") @db.Date
  updatedAt   DateTime?  @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  // Relations
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  project     Project    @relation(fields: [projectId], references: [id])
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id])

  @@map("tasks")
}

model Movement {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  projectId     String?      @map("project_id") @db.Uuid
  createdById        String       @map("created_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")
  movementDate  DateTime     @default(dbgenerated("CURRENT_DATE")) @map("movement_date") @db.Date
  amount        Decimal      @db.Decimal(15, 2)
  iva           Decimal      @db.Decimal(5, 2)
  // iva_amount y total son columnas GENERATED en BD, solo lectura en Prisma
  ivaAmount     Decimal?     @map("iva_amount") @db.Decimal(15, 2) @default(dbgenerated())
  total         Decimal?     @db.Decimal(15, 2) @default(dbgenerated())
  type          MovementType
  concept       String?      @db.VarChar(500)
  notes         String?
  updatedAt     DateTime?    @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  // Relations
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  project       Project?     @relation(fields: [projectId], references: [id])
  createdBy   User   @relation("MovementCreatedBy", fields: [createdById], references: [id])
  documents     Document[]

  @@map("movements")
}

model Document {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  projectId     String?   @map("project_id") @db.Uuid
  movementId    String?   @map("movement_id") @db.Uuid
  createdById        String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  mimeType      String   @map("mime_type") @db.VarChar(100)
  originalName  String   @map("original_name") @db.VarChar(255)
  storagePath   String   @map("storage_path") @db.VarChar(500)
  sizeBytes     BigInt   @map("size_bytes")
  updatedAt     DateTime? @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  project       Project?  @relation(fields: [projectId], references: [id])
  movement      Movement? @relation(fields: [movementId], references: [id])
  createdBy   User   @relation("DocumentCreatedBy", fields: [createdById], references: [id])

  @@map("documents")
}
